#!/bin/sh
set -eu

run_sync_check() {
	if [ "${AGENT_TOOLKIT_SYNC_CHECK:-}" = "1" ] && command -v agents >/dev/null 2>&1; then
		agents sync --path . --check
	fi
}

run_local_checks() {
	echo "[WARN] agent-toolkit unavailable; running local fallback checks" >&2

	if [ "$#" -gt 0 ] && [ "$1" = "--staged" ]; then
		git diff --cached --check
		bash plugins/dotagent/scripts/deslop.sh --staged
	else
		git diff --check
		bash plugins/dotagent/scripts/deslop.sh .
	fi

	bash -n plugins/dotagent/scripts/skill-lint.sh plugins/dotagent/scripts/deslop.sh plugins/dotagent/scripts/setup.sh plugins/dotagent/scripts/teardown.sh
	bash plugins/dotagent/scripts/skill-lint.sh plugins/dotagent/skills
	bash plugins/dotagent/scripts/skill-lint.sh plugins/dotagent/agents

	if command -v bun >/dev/null 2>&1; then
		bun -e "for (const path of ['.agents/agents.json','plugins/dotagent/.claude-plugin/plugin.json','plugins/dotagent/.codex-plugin/plugin.json','plugins/dotagent/gemini-extension/gemini-extension.json']) { JSON.parse(await Bun.file(path).text()); } console.log('json ok')"
	else
		echo "[WARN] bun unavailable; skipped JSON manifest parse fallback" >&2
	fi

	if [ "${AGENT_TOOLKIT_SYNC_CHECK:-}" = "1" ] && command -v agents >/dev/null 2>&1; then
		run_sync_check
	fi
}

if [ -n "${AGENT_TOOLKIT_BIN:-}" ]; then
	"$AGENT_TOOLKIT_BIN" repo check "$@"
	run_sync_check
	exit $?
fi

if ! command -v bunx >/dev/null 2>&1; then
	run_local_checks "$@"
	exit $?
fi

output_file=$(mktemp "${TMPDIR:-/tmp}/agent-check.XXXXXX")
if bunx @harryy/agent-toolkit repo check "$@" >"$output_file" 2>&1; then
	cat "$output_file"
	rm -f "$output_file"
	run_sync_check
	exit $?
fi

status=$?
cat "$output_file" >&2

if grep -Eq 'registry\.npmjs\.org/@harryy%2fagent-toolkit|unable to write files to tempdir|Package not found|Not found' "$output_file"; then
	rm -f "$output_file"
	run_local_checks "$@"
	exit $?
fi

rm -f "$output_file"
exit "$status"
